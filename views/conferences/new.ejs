<% layout("/layouts/boilerplate") -%>
<%- include("../includes/adminnavbar.ejs")%>
<!-- Form Section -->
    <section class="mt-5 mb-5">
    <div class="row col-10 offset-1">
    <div class="container">
            <h2>Create New MUN</h2>

            <form action="/conferences" method="POST">
                
                <!-- Title -->
                <div class="form-group">
                    <label for="title">MUN Name</label>
                    <input type="text" name="conference[title]" id="title" placeholder="e.g. KIT MUN 2026" required>
                </div>
                <div class="row">
                <!-- Conference Date -->
                <div class="form-group col-md-6">
                    <label for="conferenceDate">Conference Date</label>
                    <input type="date" name="conference[conferenceDate]" id="conferenceDate" required>
                </div>

                <!-- Registration Deadline -->
                <div class="form-group col-md-6">
                    <label for="registrationDeadline">Registration Deadline</label>
                    <input type="date" name="conference[registrationDeadline]" id="registrationDeadline">
                </div>
                </div>

                <!-- Location -->
                <div class="form-group">
                    <label for="location">Location</label>
                    <input type="text" name="conference[location]" id="location" placeholder="e.g. Nagpur, India" required>
                </div>

                <!-- Description -->
                <div class="form-group">
                    <label for="description">Description</label>
                    <textarea name="conference[description]" id="description" rows="4" placeholder="Enter a short description of the conference" required></textarea>
                </div>

                <!-- Image URL -->
                <div class="form-group">
                    <label for="image">Image URL</label>
                    <input type="text" name="conference[image][url]" id="image" placeholder="Paste image link (optional)">
                </div>

                <!-- Submit -->
                <button type="submit" class="submit-btn">Create MUN</button>

            </form>
            <form  class="cancel-link" action="/conferences">
                <button class=" btn btn-danger ">Cancel</button>   
            </form>
            
        </div>
    </div>
</section>
