<!-- <% layout("/layouts/boilerplate") -%> -->
<%- include("./includes/navbar.ejs")%>

    <!-- Hero Section -->
    <section class="hero">
        <div class="container">
            <h1 class="fw-medium"><b>Run Smarter, Fairer, Digital MUN Conferences</b></h1>
            <p>A Complete Platform for Committees, Voting & Scoring. Empowering the next generation of diplomats with cutting-edge technology.</p>
            <div class="hero-btns">
                <a href="#" class="big btn btn-warning" data-bs-toggle>Register Now</a>
                <a href="/conferences" class="big btn btn-outline-light">Continue As Admin</a>
            </div>
        </div>
    </section>

    <!-- Features Section -->
    <section class="features">
        <div class="container">
            <h2 class="section-title"><b>Platform Features</b></h2>
            <div class="features-grid">
                <div class="feature-box">
                    <h3><b>Real-Time Voting</b></h3>
                    <p>Instant results for motions and resolutions with secure digital tallies.</p>
                </div>
                <div class="feature-box">
                    <h3><b>Digital Motions</b></h3>
                    <p>Submit and track motions directly from your device without raising placards.</p>
                </div>
                <div class="feature-box">
                    <h3><b>Transparent Scoring</b></h3>
                    <p>Automated scoring system based on participation and diplomatic performance.</p>
                </div>
                <div class="feature-box">
                    <h3><b>Secure Certificates</b></h3>
                    <p>Instantly generated, verifiable digital certificates for all participants.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Committees Preview Section -->
    <section class="committees-preview">
        <div class="container">
            <h2 class="section-title"><b>Featured Committees</b></h2>
            <div class="committees-grid">
                <div class="noborder committee-card">
                    <img src="https://picsum.photos/seed/security/600/400" alt="Security Council" referrerPolicy="no-referrer">
                    <div class="card-content">
                        <h3><b>Security Council</b></h3>
                        <p>Maintaining international peace and security through collaborative diplomacy.</p>
                        <a href="#" class="view-btn">View Details &rarr;</a>
                    </div>
                </div>
                <div class="noborder committee-card">
                    <img src="https://picsum.photos/seed/climate/600/400" alt="UNEP" referrerPolicy="no-referrer">
                    <div class="card-content">
                        <h3><b>UNEP</b></h3>
                        <p>Addressing global environmental challenges and promoting sustainable development.</p>
                        <a href="#" class="view-btn">View Details &rarr;</a>
                    </div>
                </div>
                <div class="noborder committee-card">
                    <img src="https://picsum.photos/seed/health/600/400" alt="WHO" referrerPolicy="no-referrer">
                    <div class="card-content">
                        <h3><b>WHO</b></h3>
                        <p>Directing and coordinating international health work within the United Nations.</p>
                        <a href="#" class="view-btn">View Details &rarr;</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
        <p>&copy; 2026 MUNify Platform. All rights reserved.</p>
    </footer>